<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_primary"
    android:fillViewport="true"
    tools:context=".ui.systemstatus.SystemStatusFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <include
            android:id="@+id/systemStatusHeader"
            layout="@layout/include_albers_header" />

        <TextView
            android:id="@+id/systemStatusTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="System Status"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/systemStatusTopActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Back"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/helpButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Help"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/systemSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/systemNominalIcon"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:contentDescription="System nominal"
                android:src="@drawable/ic_system_status" />

            <TextView
                android:id="@+id/systemSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="All monitored values are nominal"
                android:textColor="@color/status_on"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/pumpStatusGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/pumpOneCard"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/pumpOneIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="Pump 1"
                    android:src="@drawable/ic_pump_1" />

                <TextView
                    android:id="@+id/pumpOneTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="Pump 1"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pumpOneStateText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Ready"
                    android:textColor="@color/status_on" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/pumpTwoCard"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/pumpTwoIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="Pump 2"
                    android:src="@drawable/ic_pump_2" />

                <TextView
                    android:id="@+id/pumpTwoTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="Pump 2"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pumpTwoStateText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Ready"
                    android:textColor="@color/status_on" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/batteryStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_rounded"
            android:orientation="horizontal"
            android:padding="18dp">

            <ImageView
                android:id="@+id/batteryStatusIcon"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:contentDescription="Battery"
                android:src="@drawable/ic_low_battery" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/batteryStatusTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Battery"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/batteryStatusValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--% charge"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/pressureStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_warning_box"
            android:padding="16dp"
            android:text="Pressure and current warnings will appear here."
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</ScrollView>

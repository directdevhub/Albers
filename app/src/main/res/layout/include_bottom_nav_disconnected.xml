<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavDisconnectedContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_screen_primary"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingTop="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/systemStatusNavButton"
            android:layout_width="114dp"
            android:layout_height="124dp"
            android:alpha="1"
            android:src="@drawable/ic_system_icon"
            android:scaleType="centerInside"
            android:clickable="true"
            android:enabled="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageView
            android:id="@+id/settingsNavButton"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:alpha="1"
            android:src="@drawable/ic_setting"
            android:scaleType="centerInside"
            android:clickable="true"
            android:enabled="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/rinseNavButton"
            app:layout_constraintStart_toEndOf="@+id/systemStatusNavButton"/>

        <ImageView
            android:id="@+id/rinseNavButton"
            android:layout_width="114dp"
            android:layout_height="124dp"
            android:alpha="1"
            android:src="@drawable/ic_rinse_sanitize"
            android:scaleType="centerInside"
            android:clickable="true"
            android:enabled="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/helpNavButton"
        android:layout_width="114dp"
        android:layout_height="124dp"
        android:alpha="1"
        android:src="@drawable/ic_help"
        android:scaleType="centerInside"
        android:clickable="true"
        android:enabled="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</LinearLayout>

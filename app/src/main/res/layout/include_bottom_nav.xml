<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNavContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingTop="12dp">

    <TextView
        android:id="@+id/systemStatusNavButton"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_nav_item"
        android:clickable="true"
        android:drawableTop="@drawable/ic_system_status"
        android:focusable="true"
        android:gravity="center"
        android:padding="8dp"
        android:text="System\nStatus"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/settingsNavButton"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_nav_item"
        android:clickable="true"
        android:drawableTop="@drawable/ic_settings"
        android:focusable="true"
        android:gravity="center"
        android:padding="8dp"
        android:text="Settings"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/rinseNavButton"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_nav_item"
        android:clickable="true"
        android:drawableTop="@drawable/ic_rinse_sanitize"
        android:focusable="true"
        android:gravity="center"
        android:padding="8dp"
        android:text="Rinse\nSanitize"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/helpNavButton"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_bottom_nav_item"
        android:clickable="true"
        android:drawableTop="@drawable/ic_help"
        android:focusable="true"
        android:gravity="center"
        android:padding="8dp"
        android:text="Help"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_primary"
    android:fillViewport="true"
    tools:context=".ui.help.HelpFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/helpTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_help"
            android:drawablePadding="12dp"
            android:text="Help"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_secondary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Back"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/helpIntroText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Troubleshooting guidance for ALBERS connection, battery, pump, and rinse actions."
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/helpConnectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_rounded"
            android:drawableStart="@drawable/ic_power"
            android:drawablePadding="12dp"
            android:padding="16dp"
            android:text="Connection: turn on Albers_BLE_BAL3, pair with PIN 333333, then tap Find ALBERS Device."
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/helpPumpCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_rounded"
            android:drawableStart="@drawable/ic_pump_1"
            android:drawablePadding="12dp"
            android:padding="16dp"
            android:text="Pump: PUMP NOW starts an immediate cycle. STOP cancels active pumping."
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/helpBatteryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_warning_box"
            android:drawableStart="@drawable/ic_low_battery"
            android:drawablePadding="12dp"
            android:padding="16dp"
            android:text="Battery: warnings appear when charge or power state requires attention."
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/helpPrivacyCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_rounded"
            android:drawableStart="@drawable/ic_privacy_security"
            android:drawablePadding="12dp"
            android:padding="16dp"
            android:text="Privacy and security: device data is intended for local monitoring and diagnostics."
            android:textColor="@color/text_primary" />

    </LinearLayout>

</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_primary"
    android:fillViewport="true"
    tools:context=".ui.connect.ConnectFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="720dp"
        android:orientation="vertical"
        android:padding="24dp">

        <include
            android:id="@+id/startHeader"
            layout="@layout/include_albers_header" />

        <LinearLayout
            android:id="@+id/startPowerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/startHeader">

            <ImageView
                android:id="@+id/scanButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="40dp"
                android:alpha="0.2"
                android:clickable="true"
                android:scaleType="centerInside"
                android:src="@drawable/ic_scan_button" />

            <ImageView
                android:id="@+id/startStopButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="40dp"
                android:alpha="0.2"
                android:enabled="false"
                android:scaleType="centerInside"
                android:src="@drawable/ic_start_stop_button" />

        </LinearLayout>


        <LinearLayout
            android:id="@+id/statusPowerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/startPowerRow">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/turn_on_albers_ble_bal3_pair_with_pin_333333_if_needed_then_find_the_device_here"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/selectedDeviceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Selected device: none"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_disabled"
                android:clickable="true"
                android:enabled="false"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/connect"
                android:textColor="@color/disabled_text"
                android:textStyle="bold"
                android:visibility="visible" />

        </LinearLayout>


        <LinearLayout
            android:id="@+id/startTimerBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="18dp"
            app:layout_constraintTop_toBottomOf="@+id/statusPowerRow">

            <TextView
                android:id="@+id/startTimerText"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp"
                android:alpha="0.2"
                android:gravity="center"
                android:text="--:--:--"
                android:textColor="@color/white"
                android:textSize="48sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/startTimerLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.2"
                android:gravity="center"
                android:text="@string/automatic_pump_cycle_countdown"
                android:textColor="@color/white"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/startDisabledHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:alpha="0.2"
                android:gravity="center"
                android:text="@string/controls_unlock_after_connection"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:visibility="visible" />

            <TextView
                android:id="@+id/timerOverrideButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="48dp"
                android:alpha="0.2"
                android:enabled="false"
                android:gravity="center"
                android:text="@string/timer_override"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pumpNowButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:alpha="0.2"
                android:background="@drawable/bg_timer_window"
                android:enabled="false"
                android:gravity="center"
                android:text="@string/pump_now"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/openDashboardButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:alpha="0.2"
                android:background="@drawable/bg_button_disabled"
                android:clickable="true"
                android:enabled="false"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/open_dashboard"
                android:textColor="@color/disabled_text"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <include
                android:id="@+id/connectBottomNav"
                layout="@layout/include_bottom_nav_disconnected" />

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_primary"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".ui.connect.ConnectFragment">

    <TextView
        android:id="@+id/connectTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connect to ALBERS"
        android:textColor="@color/text_primary"
        android:textAppearance="?attr/textAppearanceHeadlineSmall" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Ready to scan for the ALBERS BLE device."
        android:textColor="@color/text_secondary"
        android:textAppearance="?attr/textAppearanceBodyLarge" />

    <TextView
        android:id="@+id/selectedDeviceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Selected device: none"
        android:textColor="@color/text_muted"
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <TextView
        android:id="@+id/scanButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_button_green"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:importantForAccessibility="yes"
        android:minHeight="56dp"
        android:text="Scan for Device"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:textAllCaps="false" />

    <TextView
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_disabled"
        android:clickable="true"
        android:enabled="false"
        android:focusable="true"
        android:gravity="center"
        android:importantForAccessibility="yes"
        android:minHeight="56dp"
        android:text="Connect"
        android:textStyle="bold"
        android:textColor="@color/disabled_text"
        android:textAllCaps="false" />

    <TextView
        android:id="@+id/openDashboardButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_disabled"
        android:clickable="true"
        android:enabled="false"
        android:focusable="true"
        android:gravity="center"
        android:importantForAccessibility="yes"
        android:minHeight="56dp"
        android:text="Open Dashboard"
        android:textStyle="bold"
        android:textColor="@color/disabled_text"
        android:textAllCaps="false" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_primary"
    android:fillViewport="true"
    tools:context=".ui.connect.ConnectFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="720dp"
        android:orientation="vertical"
        android:padding="24dp">

        <include
            android:id="@+id/startHeader"
            layout="@layout/include_albers_header" />

        <LinearLayout
            android:id="@+id/startPowerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/scanButton"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:background="@drawable/bg_button_green"
                android:clickable="true"
                android:drawableTop="@drawable/ic_power"
                android:focusable="true"
                android:gravity="center"
                android:padding="14dp"
                android:text="START"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/startStopButton"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_marginStart="40dp"
                android:background="@drawable/bg_button_disabled"
                android:drawableTop="@drawable/ic_power"
                android:enabled="false"
                android:gravity="center"
                android:padding="14dp"
                android:text="STOP"
                android:textColor="@color/disabled_text"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Turn on Albers_BLE_BAL3, pair with PIN 333333 if needed, then find the device here."
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/selectedDeviceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Selected device: none"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_disabled"
            android:clickable="true"
            android:enabled="false"
            android:focusable="true"
            android:gravity="center"
            android:text="Connect"
            android:textColor="@color/disabled_text"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/startTimerBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/startTimerLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Automatic Pump Cycle Countdown"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/startTimerText"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_timer_window"
                android:gravity="center"
                android:text="--:--:--"
                android:textColor="@color/disabled_text"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/startDisabledHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Controls unlock after connection."
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/timerOverrideButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_disabled"
                android:enabled="false"
                android:gravity="center"
                android:text="Timer Override"
                android:textColor="@color/disabled_text"
                android:textStyle="bold" />

        </LinearLayout>

        <include layout="@layout/include_bottom_nav_disconnected" />

        <TextView
            android:id="@+id/openDashboardButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_disabled"
            android:clickable="true"
            android:enabled="false"
            android:focusable="true"
            android:gravity="center"
            android:text="Open Dashboard"
            android:textColor="@color/disabled_text"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
